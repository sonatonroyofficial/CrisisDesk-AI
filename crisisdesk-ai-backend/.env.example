# Server Port
PORT=3000

# MongoDB Connection String
# Use this for local development:
# MONGODB_URI=mongodb://127.0.0.1:27017/crisisdesk
# Use this for Docker Compose (points to the 'mongo' service name):
MONGODB_URI=mongodb://mongo:27017/crisisdesk

# Gemini API Key (Required for AI classification)
GEMINI_API_KEY=your_gemini_api_key_here

# JWT Secret (Required for admin JWT token signing)
JWT_SECRET=your_jwt_secret_here

# Admin Login Credentials (used in POST /api/admin/login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
